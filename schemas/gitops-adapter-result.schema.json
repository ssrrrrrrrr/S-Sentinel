{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/gitops-adapter-result.schema.json",
  "title": "S Sentinel GitOps Adapter Result",
  "description": "Local-only adapter delivery receipt that records how a GitOps adapter accepted and materialized a review handoff without calling an external Git provider.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "gitopsAdapterResultId",
    "generatedBy",
    "generatedAt",
    "mode",
    "release",
    "inputs",
    "adapter",
    "delivery",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "gitops.adapter.result/v1alpha1"
    },
    "gitopsAdapterResultId": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "const": "local_gitops_adapter_result"
    },
    "release": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseId",
        "service",
        "env",
        "namespace",
        "policyDecision",
        "finalAction"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseEvidence",
        "gitopsAdapterRequest",
        "gitopsHandoffBundle",
        "gitopsPRBundle"
      ]
    },
    "adapter": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "adapter",
        "adapterType",
        "deliveryMode",
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotCallExternalGitProvider"
      ],
      "properties": {
        "adapter": {
          "type": "string",
          "minLength": 1
        },
        "adapterType": {
          "type": "string",
          "minLength": 1
        },
        "deliveryMode": {
          "type": "string",
          "minLength": 1
        },
        "readOnly": {
          "type": "boolean"
        },
        "dryRunOnly": {
          "type": "boolean"
        },
        "willExecute": {
          "type": "boolean"
        },
        "doesNotCallExternalGitProvider": {
          "type": "boolean"
        },
        "emitsDeliveryReceipt": {
          "type": "boolean"
        }
      }
    },
    "delivery": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "deliveryStatus",
        "requestedOperation",
        "summary",
        "receipt",
        "outputFiles"
      ],
      "properties": {
        "deliveryStatus": {
          "type": "string",
          "enum": [
            "BLOCKED",
            "WAITING_APPROVAL",
            "RECEIPT_RECORDED",
            "NO_ACTION_REQUIRED",
            "NEEDS_MORE_EVIDENCE",
            "FAILED"
          ]
        },
        "requestedOperation": {
          "type": [
            "string",
            "null"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "receipt": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "bundleDir",
            "branchName",
            "commitMessage",
            "pullRequestTitle",
            "localOnly",
            "receivedAt",
            "processedAt"
          ]
        },
        "outputFiles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "fileId",
              "path",
              "contentType",
              "description"
            ]
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failureReason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotModifyGitOps",
        "doesNotCommit",
        "doesNotPush",
        "doesNotCreatePullRequest",
        "doesNotCallExternalGitProvider",
        "doesNotModifyKubernetes"
      ]
    }
  }
}
