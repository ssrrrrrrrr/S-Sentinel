{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/execution-result.schema.json",
  "title": "S Sentinel Execution Result",
  "description": "Controlled executor result that records what a policy-bound executor did or declined to do, and emits execution evidence without mutating GitOps or Kubernetes by default.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "executionResultId",
    "generatedBy",
    "generatedAt",
    "mode",
    "executor",
    "release",
    "inputs",
    "result",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "execution.result/v1alpha1"
    },
    "executionResultId": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "minLength": 1
    },
    "executor": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "adapter",
        "adapterType",
        "dryRunOnly",
        "readOnly",
        "willExecute",
        "mutatesGitOps",
        "mutatesKubernetes"
      ],
      "properties": {
        "adapter": {
          "type": "string",
          "minLength": 1
        },
        "adapterType": {
          "type": "string",
          "minLength": 1
        },
        "dryRunOnly": {
          "type": "boolean"
        },
        "readOnly": {
          "type": "boolean"
        },
        "willExecute": {
          "type": "boolean"
        },
        "mutatesGitOps": {
          "type": "boolean"
        },
        "mutatesKubernetes": {
          "type": "boolean"
        },
        "emitsExecutionEvidence": {
          "type": "boolean"
        }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseId",
        "service",
        "env",
        "namespace",
        "policyDecision",
        "finalAction"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseEvidence",
        "executionRequest",
        "executionEligibility",
        "executionPreview"
      ]
    },
    "result": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "executionStatus",
        "readyForExecution",
        "requestedAction",
        "summary",
        "executedActions",
        "blockedActions",
        "evidenceArtifacts"
      ],
      "properties": {
        "executionStatus": {
          "type": "string",
          "enum": [
            "NOT_EXECUTED",
            "PREVIEW_ONLY",
            "BLOCKED",
            "READY_FOR_EXECUTOR",
            "SUCCEEDED",
            "FAILED"
          ]
        },
        "readyForExecution": {
          "type": "boolean"
        },
        "requestedAction": {
          "type": [
            "string",
            "null"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "executedActions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "actionId",
              "title",
              "outcome",
              "dryRunOnly"
            ]
          }
        },
        "blockedActions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "evidenceArtifacts": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "executionLog",
            "sourceExecutionPreview"
          ]
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotModifyKubernetes",
        "doesNotModifyGitOps",
        "doesNotRollback",
        "doesNotPromote",
        "doesNotPatchResources",
        "doesNotDeleteResources",
        "doesNotBuildImages",
        "doesNotCommitOrPush"
      ]
    }
  }
}
