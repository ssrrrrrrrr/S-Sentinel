{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/gitops-adapter-handoff-prep.schema.json",
  "title": "S Sentinel GitOps Adapter Handoff Prep",
  "description": "Local-only handoff preparation result derived from the pickup transition. It records how the control plane prepares the next handoff phase without committing, pushing, creating pull requests, or modifying Kubernetes.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "gitopsAdapterHandoffPrepId",
    "generatedBy",
    "generatedAt",
    "mode",
    "release",
    "inputs",
    "handoffPrep",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "gitops.adapter.handoff.prep/v1alpha1"
    },
    "gitopsAdapterHandoffPrepId": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "const": "local_gitops_adapter_handoff_prep"
    },
    "release": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseId",
        "service",
        "env",
        "namespace",
        "policyDecision",
        "finalAction"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseEvidence",
        "gitopsAdapterPickupTransition",
        "gitopsAdapterPickupEvent",
        "gitopsAdapterHandoffState"
      ]
    },
    "handoffPrep": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "prepStatus",
        "transitionStatus",
        "eventStatus",
        "handoffStateStatus",
        "resultingStateStatus",
        "pickupStatus",
        "ackStatus",
        "branchName",
        "requestedOperation",
        "workspaceDir",
        "selectedEvent",
        "responseSource",
        "currentCheckpoint",
        "nextCheckpoint",
        "currentActor",
        "nextActor",
        "summary",
        "prepChecklist",
        "prepControl"
      ],
      "properties": {
        "prepStatus": {
          "type": "string",
          "enum": [
            "WAITING_FOR_PREP",
            "PREPARED_FOR_HANDOFF",
            "RETURNED_FOR_REWORK",
            "HANDOFF_IN_PROGRESS",
            "HANDOFF_COMPLETED",
            "WAITING_APPROVAL",
            "BLOCKED",
            "NO_ACTION_REQUIRED",
            "INVALID_TRANSITION",
            "FAILED"
          ]
        },
        "transitionStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "eventStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "handoffStateStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "resultingStateStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "pickupStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "ackStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "branchName": {
          "type": [
            "string",
            "null"
          ]
        },
        "requestedOperation": {
          "type": [
            "string",
            "null"
          ]
        },
        "workspaceDir": {
          "type": [
            "string",
            "null"
          ]
        },
        "selectedEvent": {
          "type": [
            "string",
            "null"
          ]
        },
        "responseSource": {
          "type": [
            "string",
            "null"
          ]
        },
        "currentCheckpoint": {
          "type": "string",
          "minLength": 1
        },
        "nextCheckpoint": {
          "type": "string",
          "minLength": 1
        },
        "currentActor": {
          "type": "string",
          "minLength": 1
        },
        "nextActor": {
          "type": "string",
          "minLength": 1
        },
        "preparedArtifactCount": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "prepChecklist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "prepControl": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "path",
            "summaryPath",
            "generatedAt",
            "localOnly"
          ]
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotModifyGitOps",
        "doesNotCommit",
        "doesNotPush",
        "doesNotCreatePullRequest",
        "doesNotCallExternalGitProvider",
        "doesNotModifyKubernetes"
      ]
    }
  }
}
