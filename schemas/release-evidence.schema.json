{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/release-evidence.schema.json",
  "title": "S Sentinel Release Evidence Bundle",
  "description": "Auditable release evidence bundle that links release result, policy decision, AI decision, artifacts, and safety references.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "generatedBy",
    "releaseResult",
    "policyDecision",
    "finalAction",
    "executionMode",
    "requiresHumanApproval",
    "safeToRetry",
    "summary",
    "artifacts",
    "decisionRefs"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "release.evidence.bundle/v1alpha1"
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "releaseResult": {
      "type": "string",
      "minLength": 1
    },
    "policyDecision": {
      "type": "string",
      "enum": [
        "ALLOW",
        "ALLOW_ADVISORY_ONLY",
        "DENY",
        "REQUIRE_HUMAN_APPROVAL",
        "UNKNOWN"
      ]
    },
    "finalAction": {
      "type": "string",
      "enum": [
        "NOOP",
        "STOP_PROMOTION",
        "ROLLBACK",
        "PROMOTE",
        "INVESTIGATE",
        "UNKNOWN"
      ]
    },
    "executionMode": {
      "type": "string",
      "enum": [
        "advisory_only",
        "manual_approval",
        "auto_execute_disabled",
        "auto_execute"
      ]
    },
    "requiresHumanApproval": {
      "type": "boolean"
    },
    "safeToRetry": {
      "type": "boolean"
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "rolloutPhase",
        "rolloutAbort",
        "analysisRunPhase",
        "riskLevel",
        "riskScore",
        "failedMetrics",
        "matchedPolicyRules"
      ],
      "properties": {
        "rolloutPhase": {
          "type": "string",
          "minLength": 1
        },
        "rolloutAbort": {
          "type": "boolean"
        },
        "analysisRunPhase": {
          "type": "string",
          "minLength": 1
        },
        "riskLevel": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical",
            "unknown"
          ]
        },
        "riskScore": {
          "type": [
            "integer",
            "number"
          ],
          "minimum": 0,
          "maximum": 100
        },
        "changeRiskLevel": {
          "type": [
            "string",
            "null"
          ]
        },
        "changeRiskScore": {
          "type": [
            "integer",
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 100
        },
        "failedMetrics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "matchedPolicyRules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "null"
        ]
      },
      "required": [
        "releaseContext",
        "aiDecision",
        "policyDecision",
        "releaseSummary",
        "actionPlan"
      ],
      "properties": {
        "agentRun": {
          "type": [
            "string",
            "null"
          ],
          "description": "Path to the generated read-only agent run JSON."
        },
        "planRun": {
          "type": [
            "string",
            "null"
          ],
          "description": "Path to the generated read-only planning run JSON."
        },
        "executionRequest": {
          "type": [
            "string",
            "null"
          ],
          "description": "Path to the generated policy-bound execution request JSON."
        }
      }
    },
    "decisionRefs": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "aiDecision": {
          "type": "object",
          "additionalProperties": true
        },
        "policyDecision": {
          "type": "object",
          "additionalProperties": true
        },
        "agentRun": {
          "type": "object",
          "properties": {
            "agentRunId": {
              "type": [
                "string",
                "null"
              ]
            },
            "mode": {
              "type": [
                "string",
                "null"
              ]
            },
            "recommendedAction": {
              "type": [
                "string",
                "null"
              ]
            },
            "priority": {
              "type": [
                "string",
                "null"
              ]
            },
            "willExecute": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "guardrails": {
              "type": "object"
            }
          },
          "additionalProperties": true
        },
        "planRun": {
          "type": "object",
          "properties": {
            "planRunId": {
              "type": [
                "string",
                "null"
              ]
            },
            "sourceAgentRunId": {
              "type": [
                "string",
                "null"
              ]
            },
            "mode": {
              "type": [
                "string",
                "null"
              ]
            },
            "planType": {
              "type": [
                "string",
                "null"
              ]
            },
            "priority": {
              "type": [
                "string",
                "null"
              ]
            },
            "retrievedEvidenceCount": {
              "type": [
                "integer",
                "null"
              ]
            },
            "willExecute": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "guardrails": {
              "type": "object"
            }
          },
          "additionalProperties": true
        },
        "executionRequest": {
          "type": "object",
          "properties": {
            "executionRequestId": {
              "type": [
                "string",
                "null"
              ]
            },
            "sourcePlanRunId": {
              "type": [
                "string",
                "null"
              ]
            },
            "mode": {
              "type": [
                "string",
                "null"
              ]
            },
            "requestedAction": {
              "type": [
                "string",
                "null"
              ]
            },
            "requestStatus": {
              "type": [
                "string",
                "null"
              ]
            },
            "policyDecision": {
              "type": [
                "string",
                "null"
              ]
            },
            "requiresHumanApproval": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "approvalStatus": {
              "type": [
                "string",
                "null"
              ]
            },
            "approved": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "willExecute": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "guardrails": {
              "type": "object"
            }
          },
          "additionalProperties": true
        }
      }
    },
    "failureEvidenceRef": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true,
      "properties": {
        "generated": {
          "type": "boolean"
        },
        "json": {
          "type": "string"
        },
        "markdown": {
          "type": "string"
        }
      }
    },
    "service": {
      "type": [
        "string",
        "null"
      ],
      "description": "Service name associated with the release evidence."
    },
    "env": {
      "type": [
        "string",
        "null"
      ],
      "description": "Environment associated with the release evidence."
    },
    "sloId": {
      "type": [
        "string",
        "null"
      ],
      "description": "SLO identifier copied from the release context."
    },
    "sloConfigRef": {
      "type": [
        "string",
        "null"
      ],
      "description": "Repository-relative SLO config path copied from the release context."
    },
    "sloConfigSnapshot": {
      "type": [
        "object",
        "null"
      ],
      "description": "SLO config snapshot captured at evidence generation time.",
      "additionalProperties": true
    },
    "strategyId": {
      "type": [
        "string",
        "null"
      ],
      "description": "Progressive delivery strategy identifier copied from the release context."
    },
    "strategyConfigRef": {
      "type": [
        "string",
        "null"
      ],
      "description": "Repository-relative progressive delivery strategy config path copied from the release context."
    },
    "strategyConfigSnapshot": {
      "type": [
        "object",
        "null"
      ],
      "description": "Progressive delivery strategy config snapshot captured at evidence generation time.",
      "additionalProperties": true
    },
    "policyDecisionId": {
      "type": [
        "string",
        "null"
      ],
      "description": "Policy decision identifier copied from the Policy Guard output."
    },
    "requestedAction": {
      "type": [
        "string",
        "null"
      ],
      "description": "Action requested by the AI advisor and evaluated by Policy Guard."
    },
    "allowed": {
      "type": [
        "boolean",
        "null"
      ],
      "description": "Whether Policy Guard allowed the requested action."
    },
    "deniedReasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approvalRequiredReasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "strategyPolicy": {
      "type": "object",
      "additionalProperties": true,
      "description": "Strategy-aware policy fields used by Policy Guard."
    },
    "policySafety": {
      "type": "object",
      "additionalProperties": true,
      "description": "Read-only safety flags emitted by Policy Guard."
    },
    "agentRunId": {
      "type": [
        "string",
        "null"
      ],
      "description": "Read-only agent run id linked to this release evidence bundle."
    },
    "planRunId": {
      "type": [
        "string",
        "null"
      ],
      "description": "Read-only planning run id linked to this release evidence bundle."
    },
    "executionRequestId": {
      "type": [
        "string",
        "null"
      ],
      "description": "Policy-bound execution request id linked to this release evidence bundle."
    }
  }
}
