{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/gitops-adapter-request.schema.json",
  "title": "S Sentinel GitOps Adapter Request",
  "description": "Adapter-ready review-only request derived from the materialized GitOps handoff bundle.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "gitopsAdapterRequestId",
    "generatedBy",
    "generatedAt",
    "mode",
    "release",
    "inputs",
    "request",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "gitops.adapter.request/v1alpha1"
    },
    "gitopsAdapterRequestId": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "const": "review_only_gitops_adapter_request"
    },
    "release": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseId",
        "service",
        "env",
        "namespace",
        "policyDecision",
        "finalAction"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseEvidence",
        "gitopsPatchProposal",
        "gitopsPRBundle",
        "gitopsHandoffBundle"
      ]
    },
    "request": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "requestStatus",
        "adapterType",
        "requestedOperation",
        "bundleDir",
        "delivery",
        "handoffFiles",
        "summary"
      ],
      "properties": {
        "requestStatus": {
          "type": "string",
          "enum": [
            "BLOCKED",
            "WAITING_APPROVAL",
            "READY_FOR_ADAPTER",
            "NO_ACTION_REQUIRED",
            "NEEDS_MORE_EVIDENCE"
          ]
        },
        "adapterType": {
          "type": "string",
          "minLength": 1
        },
        "requestedOperation": {
          "type": "string",
          "minLength": 1
        },
        "bundleDir": {
          "type": [
            "string",
            "null"
          ]
        },
        "delivery": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "branchName",
            "commitMessage",
            "pullRequestTitle",
            "localOnly",
            "doesNotCallExternalGitProvider"
          ]
        },
        "handoffFiles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "fileId",
              "path",
              "contentType",
              "description"
            ]
          }
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotModifyGitOps",
        "doesNotCommit",
        "doesNotPush",
        "doesNotCreatePullRequest",
        "doesNotModifyKubernetes"
      ]
    }
  }
}
