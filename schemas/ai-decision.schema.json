{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/ai-decision.schema.json",
  "title": "S Sentinel AI Decision",
  "description": "AI or deterministic advisor output for release safety analysis.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "generatedBy",
    "model",
    "releaseResult",
    "decisionSource",
    "confidence",
    "executionMode",
    "summary",
    "conclusion",
    "failedMetrics",
    "riskLevel",
    "riskScore",
    "riskReasons",
    "decision",
    "recommendedAction",
    "requiresHumanApproval",
    "safeToRetry",
    "policyHints",
    "agentAction",
    "guardrails",
    "evidence",
    "nextSteps",
    "rollout",
    "analysisRun",
    "sources"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "releaseResult": {
      "type": "string",
      "minLength": 1
    },
    "decisionSource": {
      "type": "string",
      "enum": [
        "deterministic_rule",
        "ollama",
        "llm",
        "fallback_rule",
        "unknown"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "unknown"
      ]
    },
    "executionMode": {
      "type": "string",
      "enum": [
        "advisory_only",
        "manual_approval",
        "auto_execute_disabled",
        "auto_execute"
      ]
    },
    "summary": {
      "type": "string"
    },
    "conclusion": {
      "type": "string"
    },
    "failedMetrics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "riskLevel": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical",
        "unknown"
      ]
    },
    "riskScore": {
      "type": [
        "integer",
        "number"
      ],
      "minimum": 0,
      "maximum": 100
    },
    "riskReasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changeRiskLevel": {
      "type": [
        "string",
        "null"
      ]
    },
    "changeRiskScore": {
      "type": [
        "integer",
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 100
    },
    "changeRiskHints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision": {
      "type": "string",
      "minLength": 1
    },
    "recommendedAction": {
      "type": "string",
      "minLength": 1
    },
    "requiresHumanApproval": {
      "type": "boolean"
    },
    "safeToRetry": {
      "type": "boolean"
    },
    "policyHints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "agentAction": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type",
        "allowed",
        "requiresApproval",
        "reason"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "allowed": {
          "type": "boolean"
        },
        "requiresApproval": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true
    },
    "nextSteps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rollout": {
      "type": "object",
      "additionalProperties": true
    },
    "analysisRun": {
      "type": "object",
      "additionalProperties": true
    },
    "sources": {
      "type": "object",
      "additionalProperties": true
    },
    "service": {
      "type": [
        "string",
        "null"
      ],
      "description": "Service name associated with the AI release analysis."
    },
    "env": {
      "type": [
        "string",
        "null"
      ],
      "description": "Environment associated with the AI release analysis."
    },
    "sloId": {
      "type": [
        "string",
        "null"
      ],
      "description": "SLO identifier used by the release."
    },
    "sloConfigRef": {
      "type": [
        "string",
        "null"
      ],
      "description": "Repository-relative SLO config reference."
    },
    "sloConfigSnapshot": {
      "type": [
        "object",
        "null"
      ],
      "description": "SLO config snapshot loaded by the AI advisor.",
      "additionalProperties": true
    },
    "sloObjectives": {
      "type": "array",
      "description": "SLO objectives made visible to the AI advisor.",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "strategyId": {
      "type": [
        "string",
        "null"
      ],
      "description": "Progressive delivery strategy identifier used by the release."
    },
    "strategyConfigRef": {
      "type": [
        "string",
        "null"
      ],
      "description": "Repository-relative progressive delivery strategy config reference."
    },
    "strategyConfigSnapshot": {
      "type": [
        "object",
        "null"
      ],
      "description": "Progressive delivery strategy config snapshot loaded by the AI advisor.",
      "additionalProperties": true
    },
    "strategyType": {
      "type": [
        "string",
        "null"
      ],
      "description": "Progressive delivery strategy type, such as canary."
    },
    "strategyTrafficSteps": {
      "type": "array",
      "description": "Traffic steps made visible to the AI advisor.",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "strategyFailurePolicy": {
      "type": "object",
      "description": "Failure policy made visible to the AI advisor.",
      "additionalProperties": true
    },
    "strategyPromotionPolicy": {
      "type": "object",
      "description": "Promotion policy made visible to the AI advisor.",
      "additionalProperties": true
    }
  }
}
