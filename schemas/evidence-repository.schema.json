{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/evidence-repository.schema.json",
  "title": "S Sentinel Evidence Repository",
  "description": "Repository descriptor for the Evidence API query model.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "repositoryId",
    "repositoryType",
    "mode",
    "runtimeMode",
    "backend",
    "adapter",
    "storage",
    "queryModel",
    "contractVersion",
    "readOnly",
    "willExecute",
    "supportsListReleases",
    "supportsGetRelease",
    "supportsGetObject",
    "supportsListArtifacts",
    "supportsSearch",
    "supportsVerificationSummary",
    "supportsGraph",
    "supportsNativeSQLite",
    "supportsRemoteApi"
  ],
  "properties": {
    "repositoryId": { "type": "string", "minLength": 1 },
    "repositoryType": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "minLength": 1 },
    "runtimeMode": { "type": "string", "minLength": 1 },
    "backend": { "type": "string", "minLength": 1 },
    "adapter": { "type": "string", "minLength": 1 },
    "storage": { "type": "string", "minLength": 1 },
    "queryModel": { "type": "string", "minLength": 1 },
    "contractVersion": {
      "type": "string",
      "const": "evidence.repository/v1alpha1"
    },
    "readOnly": { "type": "boolean" },
    "willExecute": { "type": "boolean" },
    "supportsListReleases": { "type": "boolean" },
    "supportsGetRelease": { "type": "boolean" },
    "supportsGetObject": { "type": "boolean" },
    "supportsListArtifacts": { "type": "boolean" },
    "supportsSearch": { "type": "boolean" },
    "supportsVerificationSummary": { "type": "boolean" },
    "supportsGraph": { "type": "boolean" },
    "supportsNativeSQLite": { "type": "boolean" },
    "supportsRemoteApi": { "type": "boolean" },
    "description": { "type": "string" }
  }
}
