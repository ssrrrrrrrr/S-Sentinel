{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "S Sentinel Signed Release Gate",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "signedReleaseGateId",
    "generatedBy",
    "generatedAt",
    "mode",
    "source",
    "release",
    "image",
    "attestations",
    "checks",
    "decision",
    "risk",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "signed.release.gate/v1alpha1"
    },
    "signedReleaseGateId": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": ["read_only_signed_release_gate"]
    },
    "decision": {
      "type": "object",
      "required": [
        "decision",
        "allowed",
        "requiresHumanApproval",
        "blockingReasons",
        "warningReasons"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["ALLOW", "REQUIRE_HUMAN_APPROVAL", "BLOCK"]
        },
        "allowed": {
          "type": "boolean"
        },
        "requiresHumanApproval": {
          "type": "boolean"
        },
        "blockingReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "warningReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "guardrails": {
      "type": "object",
      "required": [
        "readOnly",
        "willExecute",
        "doesNotSignImages",
        "doesNotVerifyExternalServices",
        "doesNotModifyKubernetes",
        "doesNotModifyGitOps",
        "doesNotBuildImages",
        "doesNotPushImages",
        "doesNotCommitOrPush"
      ]
    }
  }
}
