{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/gitops-adapter-dispatch.schema.json",
  "title": "S Sentinel GitOps Adapter Dispatch",
  "description": "External-adapter-style stub dispatch derived from the local GitOps adapter payload. It records what would be handed to a real Git provider integration without actually creating branches, commits, pushes, or pull requests.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "gitopsAdapterDispatchId",
    "generatedBy",
    "generatedAt",
    "mode",
    "release",
    "inputs",
    "dispatch",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "gitops.adapter.dispatch/v1alpha1"
    },
    "gitopsAdapterDispatchId": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "const": "external_gitops_adapter_stub_dispatch"
    },
    "release": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseId",
        "service",
        "env",
        "namespace",
        "policyDecision",
        "finalAction"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseEvidence",
        "gitopsAdapterPayload",
        "gitopsAdapterDelivery",
        "gitopsPRBundle"
      ]
    },
    "dispatch": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "dispatchStatus",
        "adapterType",
        "dispatchMode",
        "payloadStatus",
        "branchName",
        "requestedOperation",
        "payloadDir",
        "providerRequestPath",
        "dispatchReceipt",
        "dispatchChecklist",
        "summary"
      ],
      "properties": {
        "dispatchStatus": {
          "type": "string",
          "enum": [
            "STUB_DISPATCHED",
            "WAITING_APPROVAL",
            "BLOCKED",
            "RETURNED_FOR_REWORK",
            "NO_ACTION_REQUIRED",
            "NEEDS_MORE_EVIDENCE",
            "FAILED"
          ]
        },
        "adapterType": {
          "type": "string",
          "minLength": 1
        },
        "dispatchMode": {
          "type": "string",
          "minLength": 1
        },
        "payloadStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "branchName": {
          "type": [
            "string",
            "null"
          ]
        },
        "requestedOperation": {
          "type": [
            "string",
            "null"
          ]
        },
        "payloadDir": {
          "type": [
            "string",
            "null"
          ]
        },
        "payloadManifestPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "commitPayloadPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "providerRequestPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "patchEntryCount": {
          "type": "integer",
          "minimum": 0
        },
        "workspaceArtifactCount": {
          "type": "integer",
          "minimum": 0
        },
        "dispatchReceipt": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "path",
            "summaryPath",
            "generatedAt",
            "localOnly"
          ]
        },
        "dispatchChecklist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotModifyGitOps",
        "doesNotCommit",
        "doesNotPush",
        "doesNotCreatePullRequest",
        "doesNotCallExternalGitProvider",
        "doesNotModifyKubernetes"
      ]
    }
  }
}
