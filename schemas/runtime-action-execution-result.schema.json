{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/runtime-action-execution-result.schema.json",
  "title": "S Sentinel Runtime Action Execution Result",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "runtimeActionExecutionResultId",
    "generatedBy",
    "generatedAt",
    "mode",
    "sourceRuntimeActionPreflightId",
    "release",
    "target",
    "executor",
    "action",
    "writeGate",
    "beforeSnapshot",
    "afterSnapshot",
    "result",
    "receipt",
    "evidenceRefs",
    "guardrails",
    "postActionVerification"
  ],
  "properties": {
    "schemaVersion": {
      "const": "runtime.action.execution.result/v1alpha1"
    },
    "runtimeActionExecutionResultId": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "const": "controlled_runtime_action_result"
    },
    "executor": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "executorName",
        "executorType",
        "adapter",
        "adapterType",
        "dryRunOnly",
        "readOnly",
        "willExecute",
        "mutatesKubernetes",
        "mutatesGitOps"
      ],
      "properties": {
        "willExecute": {
          "type": "boolean"
        },
        "mutatesKubernetes": {
          "type": "boolean"
        },
        "mutatesGitOps": {
          "type": "boolean"
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "requestedAction",
        "supportedAction",
        "actionStatus",
        "commandWillExecute"
      ],
      "properties": {
        "requestedAction": {
          "enum": [
            "NOOP",
            "REQUIRE_REVIEW",
            "PAUSE_ROLLOUT",
            "RESUME_ROLLOUT",
            "PROMOTE_ROLLOUT",
            "ABORT_ROLLOUT",
            "ROLLBACK_ROLLOUT"
          ]
        },
        "commandWillExecute": {
          "type": "boolean"
        }
      }
    },
    "writeGate": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "preflightRequired",
        "preflightStatus",
        "eligibilityStatus",
        "preflightPassed",
        "globalGateEnv",
        "globalGateEnabled",
        "operationGateEnv",
        "operationGateEnabled",
        "operation",
        "overallGateStatus",
        "writeAllowed",
        "willExecute"
      ],
      "properties": {
        "operation": {
          "enum": [
            "PAUSE_ROLLOUT",
            "RESUME_ROLLOUT",
            "PROMOTE_ROLLOUT",
            "ABORT_ROLLOUT",
            "ROLLBACK_ROLLOUT"
          ]
        },
        "overallGateStatus": {
          "type": "string",
          "minLength": 1
        },
        "writeAllowed": {
          "type": "boolean"
        },
        "willExecute": {
          "type": "boolean"
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "executionStatus",
        "actionStatus",
        "requestedAction",
        "didPause",
        "didResume",
        "didPromote",
        "didAbort",
        "didRollback",
        "mutatedKubernetes",
        "mutatedGitOps",
        "readyForExecutor",
        "willExecute",
        "summary",
        "verificationStatus",
        "pauseVerified"
      ],
      "properties": {
        "executionStatus": {
          "enum": [
            "NOT_EXECUTED",
            "SUCCEEDED",
            "FAILED"
          ]
        },
        "didPause": {
          "type": "boolean"
        },
        "mutatedKubernetes": {
          "type": "boolean"
        },
        "willExecute": {
          "type": "boolean"
        },
        "verificationStatus": {
          "type": "string",
          "minLength": 1
        },
        "pauseVerified": {
          "type": "boolean"
        }
      }
    },
    "receipt": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "receiptType",
        "receiptStatus",
        "wroteEvidence",
        "didPause",
        "didModifyKubernetes",
        "didModifyGitOps",
        "verificationStatus",
        "pauseVerified"
      ]
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "contractOnly",
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotModifyKubernetes",
        "doesNotModifyGitOps",
        "doesNotCommitOrPush",
        "postActionVerified"
      ]
    },
    "postActionVerification": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "verificationType",
        "verificationStatus",
        "requestedAction",
        "commandSucceeded",
        "postActionObserved",
        "desiredStateObserved",
        "pauseVerified",
        "expectedPaused",
        "observedPaused",
        "observedSpecPaused",
        "observedStatusPaused",
        "blockingReasons",
        "warningReasons"
      ],
      "properties": {
        "verificationType": {
          "const": "runtime_action_post_action_verification"
        },
        "verificationStatus": {
          "enum": [
            "NOT_RUN",
            "COMMAND_FAILED",
            "OBSERVATION_FAILED",
            "VERIFY_FAILED",
            "VERIFIED"
          ]
        },
        "requestedAction": {
          "enum": [
            "NOOP",
            "REQUIRE_REVIEW",
            "PAUSE_ROLLOUT",
            "RESUME_ROLLOUT",
            "PROMOTE_ROLLOUT",
            "ABORT_ROLLOUT",
            "ROLLBACK_ROLLOUT"
          ]
        },
        "commandSucceeded": {
          "type": "boolean"
        },
        "postActionObserved": {
          "type": "boolean"
        },
        "desiredStateObserved": {
          "type": "boolean"
        },
        "pauseVerified": {
          "type": "boolean"
        },
        "expectedPaused": {
          "type": "boolean"
        },
        "observedPaused": {
          "type": "boolean"
        },
        "observedSpecPaused": {
          "type": "boolean"
        },
        "observedStatusPaused": {
          "type": "boolean"
        },
        "blockingReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "warningReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "afterSnapshot": {
      "type": "object",
      "additionalProperties": true
    },
    "rollbackTarget": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "strategy": {
          "type": "string"
        },
        "targetRevision": {
          "type": [
            "integer",
            "null"
          ]
        },
        "targetStableRS": {
          "type": [
            "string",
            "null"
          ]
        },
        "targetPodHash": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "type": "string"
        },
        "commandArgumentMode": {
          "type": "string"
        },
        "usesArgoRolloutsUndo": {
          "type": "boolean"
        },
        "usesGitOpsRollback": {
          "type": "boolean"
        },
        "requiresGitOpsWrite": {
          "type": "boolean"
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "executionSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "requestedAction",
        "didExecute",
        "willExecute",
        "verified",
        "verificationStatus",
        "executionStatus",
        "actionStatus",
        "commandMode",
        "mutationTarget",
        "mutatedKubernetes",
        "mutatedGitOps",
        "riskLevel"
      ],
      "properties": {
        "requestedAction": {
          "type": "string",
          "minLength": 1
        },
        "didExecute": {
          "type": "boolean"
        },
        "willExecute": {
          "type": "boolean"
        },
        "verified": {
          "type": "boolean"
        },
        "verificationStatus": {
          "type": "string",
          "minLength": 1
        },
        "executionStatus": {
          "enum": [
            "NOT_EXECUTED",
            "SUCCEEDED",
            "FAILED"
          ]
        },
        "actionStatus": {
          "type": "string",
          "minLength": 1
        },
        "commandMode": {
          "type": "string",
          "minLength": 1
        },
        "mutationTarget": {
          "type": "string",
          "minLength": 1
        },
        "mutatedKubernetes": {
          "type": "boolean"
        },
        "mutatedGitOps": {
          "type": "boolean"
        },
        "riskLevel": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
