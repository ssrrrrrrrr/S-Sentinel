{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/gitops-handoff-bundle.schema.json",
  "title": "S Sentinel GitOps Handoff Bundle",
  "description": "Materialized review-only handoff bundle derived from the PR-ready GitOps bundle.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "gitopsHandoffBundleId",
    "generatedBy",
    "generatedAt",
    "mode",
    "release",
    "inputs",
    "handoff",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "gitops.handoff.bundle/v1alpha1"
    },
    "gitopsHandoffBundleId": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "const": "review_only_gitops_handoff_bundle"
    },
    "release": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseId",
        "service",
        "env",
        "namespace",
        "policyDecision",
        "finalAction"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseEvidence",
        "gitopsPatchProposal",
        "gitopsPRBundle"
      ]
    },
    "handoff": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "handoffStatus",
        "bundleDir",
        "materializedFiles",
        "branchName",
        "commitMessage",
        "pullRequestTitle",
        "patchEntryCount",
        "handoffChecklistCount"
      ],
      "properties": {
        "handoffStatus": {
          "type": "string",
          "enum": [
            "BLOCKED",
            "WAITING_APPROVAL",
            "READY_FOR_REVIEW",
            "NO_CHANGES_REQUIRED",
            "NEEDS_MORE_EVIDENCE"
          ]
        },
        "bundleDir": {
          "type": [
            "string",
            "null"
          ]
        },
        "materializedFiles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "fileId",
              "path",
              "contentType",
              "description"
            ]
          }
        },
        "branchName": {
          "type": [
            "string",
            "null"
          ]
        },
        "commitMessage": {
          "type": [
            "string",
            "null"
          ]
        },
        "pullRequestTitle": {
          "type": [
            "string",
            "null"
          ]
        },
        "summary": {
          "type": "string"
        },
        "patchEntryCount": {
          "type": "integer",
          "minimum": 0
        },
        "handoffChecklistCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotModifyGitOps",
        "doesNotCommit",
        "doesNotPush",
        "doesNotCreatePullRequest",
        "doesNotModifyKubernetes"
      ]
    }
  }
}
