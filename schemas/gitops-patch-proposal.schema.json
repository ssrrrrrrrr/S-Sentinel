{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/gitops-patch-proposal.schema.json",
  "title": "S Sentinel GitOps Patch Proposal",
  "description": "Review-only GitOps patch proposal derived from execution preview and rendered release plan outputs.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "gitopsPatchProposalId",
    "generatedBy",
    "generatedAt",
    "mode",
    "release",
    "inputs",
    "proposal",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "gitops.patch.proposal/v1alpha1"
    },
    "gitopsPatchProposalId": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "const": "review_only_gitops_patch_proposal"
    },
    "release": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseId",
        "service",
        "env",
        "namespace",
        "policyDecision",
        "finalAction"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseEvidence",
        "executionPreview",
        "executionResult",
        "renderedReleasePlan",
        "environmentConfig"
      ]
    },
    "proposal": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "proposalStatus",
        "requestedAction",
        "summary",
        "overlayPath",
        "patchSet",
        "blockedChanges",
        "reviewHints"
      ],
      "properties": {
        "proposalStatus": {
          "type": "string",
          "enum": [
            "BLOCKED",
            "WAITING_APPROVAL",
            "READY_FOR_REVIEW",
            "NO_CHANGES_REQUIRED",
            "NEEDS_MORE_EVIDENCE"
          ]
        },
        "requestedAction": {
          "type": [
            "string",
            "null"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "overlayPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "repository": {
          "type": "object",
          "additionalProperties": true
        },
        "patchSet": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "patchId",
              "changeType",
              "path",
              "summary",
              "dryRunOnly"
            ]
          }
        },
        "blockedChanges": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "reviewHints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotModifyGitOps",
        "doesNotCommit",
        "doesNotPush",
        "doesNotCreatePullRequest",
        "doesNotModifyKubernetes"
      ]
    }
  }
}
