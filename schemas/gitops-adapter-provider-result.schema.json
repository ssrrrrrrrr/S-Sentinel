{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/gitops-adapter-provider-result.schema.json",
  "title": "S Sentinel GitOps Adapter Provider Result",
  "description": "Provider-ready GitOps PR integration result that materializes a local PR package without creating a real remote pull request.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "gitopsAdapterProviderResultId",
    "generatedBy",
    "generatedAt",
    "mode",
    "release",
    "inputs",
    "providerResult",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "gitops.adapter.provider.result/v1alpha1"
    },
    "gitopsAdapterProviderResultId": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "const": "provider_ready_gitops_pr_result"
    },
    "release": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseId",
        "service",
        "env",
        "namespace",
        "policyDecision",
        "finalAction"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseEvidence",
        "gitopsAdapterProviderRequest",
        "gitopsAdapterDispatch",
        "gitopsAdapterPayload"
      ]
    },
    "providerResult": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "resultStatus",
        "providerType",
        "branchName",
        "requestedOperation",
        "packageDir",
        "packageManifestPath",
        "providerRequestPath",
        "summary"
      ],
      "properties": {
        "resultStatus": {
          "type": "string",
          "enum": [
            "PROVIDER_RESULT_READY",
            "WAITING_APPROVAL",
            "BLOCKED",
            "RETURNED_FOR_REWORK",
            "NO_ACTION_REQUIRED",
            "NEEDS_MORE_EVIDENCE",
            "FAILED"
          ]
        },
        "providerType": {
          "type": "string",
          "minLength": 1
        },
        "branchName": {
          "type": [
            "string",
            "null"
          ]
        },
        "requestedOperation": {
          "type": [
            "string",
            "null"
          ]
        },
        "packageDir": {
          "type": [
            "string",
            "null"
          ]
        },
        "packageManifestPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "branchNamePath": {
          "type": [
            "string",
            "null"
          ]
        },
        "commitMessagePath": {
          "type": [
            "string",
            "null"
          ]
        },
        "pullRequestTitlePath": {
          "type": [
            "string",
            "null"
          ]
        },
        "pullRequestBodyPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "providerRequestPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "patchEntryCount": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "workspaceArtifactCount": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "materializedFileCount": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "materializedFiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotModifyGitOps",
        "doesNotCommit",
        "doesNotPush",
        "doesNotCreatePullRequest",
        "doesNotCallExternalGitProvider",
        "doesNotModifyKubernetes"
      ]
    }
  }
}
