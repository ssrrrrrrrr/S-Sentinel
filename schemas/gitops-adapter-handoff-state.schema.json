{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/gitops-adapter-handoff-state.schema.json",
  "title": "S Sentinel GitOps Adapter Handoff State",
  "description": "Local-only handoff lifecycle state derived from pickup acknowledgement. It tracks the next handoff checkpoint without committing, pushing, creating pull requests, or modifying Kubernetes.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "gitopsAdapterHandoffStateId",
    "generatedBy",
    "generatedAt",
    "mode",
    "release",
    "inputs",
    "handoffState",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "gitops.adapter.handoff.state/v1alpha1"
    },
    "gitopsAdapterHandoffStateId": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "const": "local_gitops_adapter_handoff_state"
    },
    "release": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseId",
        "service",
        "env",
        "namespace",
        "policyDecision",
        "finalAction"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseEvidence",
        "gitopsAdapterPickup",
        "gitopsAdapterPickupAck",
        "gitopsAdapterRun",
        "gitopsAdapterDelivery"
      ]
    },
    "handoffState": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "stateStatus",
        "ackStatus",
        "pickupStatus",
        "branchName",
        "requestedOperation",
        "workspaceDir",
        "currentCheckpoint",
        "nextCheckpoint",
        "currentActor",
        "nextActor",
        "summary",
        "stateControl"
      ],
      "properties": {
        "stateStatus": {
          "type": "string",
          "enum": [
            "BLOCKED",
            "WAITING_APPROVAL",
            "READY_FOR_ACKNOWLEDGEMENT",
            "PICKUP_ACCEPTED",
            "PICKUP_RETURNED",
            "HANDOFF_IN_PROGRESS",
            "HANDOFF_COMPLETED",
            "NO_ACTION_REQUIRED",
            "FAILED"
          ]
        },
        "ackStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "pickupStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "branchName": {
          "type": [
            "string",
            "null"
          ]
        },
        "requestedOperation": {
          "type": [
            "string",
            "null"
          ]
        },
        "workspaceDir": {
          "type": [
            "string",
            "null"
          ]
        },
        "currentCheckpoint": {
          "type": "string",
          "minLength": 1
        },
        "nextCheckpoint": {
          "type": "string",
          "minLength": 1
        },
        "currentActor": {
          "type": "string",
          "minLength": 1
        },
        "nextActor": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "stateControl": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "path",
            "summaryPath",
            "generatedAt",
            "localOnly"
          ]
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotModifyGitOps",
        "doesNotCommit",
        "doesNotPush",
        "doesNotCreatePullRequest",
        "doesNotCallExternalGitProvider",
        "doesNotModifyKubernetes"
      ]
    }
  }
}
