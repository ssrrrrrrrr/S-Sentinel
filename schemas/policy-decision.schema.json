{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/policy-decision.schema.json",
  "title": "S Sentinel Policy Decision",
  "description": "Policy evaluator output that converts AI or rule-based release advice into a bounded safety decision.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "policyDecision",
    "finalAction",
    "executionMode",
    "requiresHumanApproval",
    "reason",
    "matchedRules",
    "inputSummary",
    "policyRef"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "release.policy.evaluator/v1alpha1"
    },
    "sourceDecisionFile": {
      "type": "string"
    },
    "policyDecision": {
      "type": "string",
      "enum": [
        "ALLOW",
        "ALLOW_ADVISORY_ONLY",
        "DENY",
        "REQUIRE_HUMAN_APPROVAL",
        "UNKNOWN"
      ]
    },
    "finalAction": {
      "type": "string",
      "enum": [
        "NOOP",
        "STOP_PROMOTION",
        "ROLLBACK",
        "PROMOTE",
        "INVESTIGATE",
        "UNKNOWN"
      ]
    },
    "executionMode": {
      "type": "string",
      "enum": [
        "advisory_only",
        "manual_approval",
        "auto_execute_disabled",
        "auto_execute"
      ]
    },
    "requiresHumanApproval": {
      "type": "boolean"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "matchedRules": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "inputSummary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseResult",
        "agentActionType",
        "agentActionAllowed",
        "agentActionRequiresApproval",
        "autoExecute"
      ],
      "properties": {
        "releaseResult": {
          "type": "string",
          "minLength": 1
        },
        "agentActionType": {
          "type": "string",
          "minLength": 1
        },
        "agentActionAllowed": {
          "type": "boolean"
        },
        "agentActionRequiresApproval": {
          "type": "boolean"
        },
        "autoExecute": {
          "type": "boolean"
        }
      }
    },
    "policyRef": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "file",
        "loaded",
        "schemaVersion"
      ],
      "properties": {
        "file": {
          "type": "string",
          "minLength": 1
        },
        "loaded": {
          "type": "boolean"
        },
        "schemaVersion": {
          "minLength": 1,
          "description": "Optional policy schema version. It may be null when the policy file does not declare schemaVersion."
        }
      }
    },
    "policyDecisionId": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "description": "Stable policy decision identifier derived from the source AI decision."
    },
    "releaseId": {
      "type": [
        "string",
        "null"
      ],
      "description": "Release identifier when it can be inferred from the source decision filename or evidence."
    },
    "evidenceId": {
      "type": [
        "string",
        "null"
      ],
      "description": "Evidence record identifier when available."
    },
    "service": {
      "type": [
        "string",
        "null"
      ]
    },
    "env": {
      "type": [
        "string",
        "null"
      ]
    },
    "sloId": {
      "type": [
        "string",
        "null"
      ]
    },
    "strategyId": {
      "type": [
        "string",
        "null"
      ]
    },
    "requestedAction": {
      "type": [
        "string",
        "null"
      ],
      "description": "Action requested or recommended by the AI advisor."
    },
    "allowed": {
      "type": [
        "boolean",
        "null"
      ],
      "description": "Whether the requested action is allowed by Policy Guard."
    },
    "deniedReasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "approvalRequiredReasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "strategyPolicy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "strategyId": {
          "type": [
            "string",
            "null"
          ]
        },
        "strategyType": {
          "type": [
            "string",
            "null"
          ]
        },
        "onSLOFailure": {
          "type": [
            "string",
            "null"
          ]
        },
        "onAnalysisError": {
          "type": [
            "string",
            "null"
          ]
        },
        "onInsufficientTraffic": {
          "type": [
            "string",
            "null"
          ]
        },
        "rollbackAllowed": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "autoPromotionEnabled": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "requiresHumanApproval": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "finalPromotionMode": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "readOnly": {
          "type": "boolean"
        },
        "willExecute": {
          "type": "boolean"
        },
        "autoExecute": {
          "type": "boolean"
        },
        "advisoryOnly": {
          "type": "boolean"
        },
        "dangerousAction": {
          "type": "boolean"
        },
        "strategyBound": {
          "type": "boolean"
        }
      }
    }
  }
}
