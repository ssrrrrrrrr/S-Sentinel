{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/gitops-adapter-pickup-transition.schema.json",
  "title": "S Sentinel GitOps Adapter Pickup Transition",
  "description": "Local-only pickup transition result derived from the pickup event envelope. It records how the control plane would progress after a local accept/return response without committing, pushing, creating pull requests, or modifying Kubernetes.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "gitopsAdapterPickupTransitionId",
    "generatedBy",
    "generatedAt",
    "mode",
    "release",
    "inputs",
    "pickupTransition",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "gitops.adapter.pickup.transition/v1alpha1"
    },
    "gitopsAdapterPickupTransitionId": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "const": "local_gitops_adapter_pickup_transition"
    },
    "release": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseId",
        "service",
        "env",
        "namespace",
        "policyDecision",
        "finalAction"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseEvidence",
        "gitopsAdapterPickupEvent",
        "gitopsAdapterHandoffState"
      ]
    },
    "pickupTransition": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "transitionStatus",
        "eventStatus",
        "handoffStateStatus",
        "pickupStatus",
        "ackStatus",
        "branchName",
        "requestedOperation",
        "workspaceDir",
        "requestedEvent",
        "selectedEvent",
        "responseSource",
        "resultingStateStatus",
        "currentCheckpoint",
        "nextCheckpoint",
        "currentActor",
        "nextActor",
        "summary",
        "transitionControl"
      ],
      "properties": {
        "transitionStatus": {
          "type": "string",
          "enum": [
            "WAITING_FOR_RESOLUTION",
            "PICKUP_ACCEPTED",
            "PICKUP_RETURNED",
            "HANDOFF_IN_PROGRESS",
            "HANDOFF_COMPLETED",
            "WAITING_APPROVAL",
            "BLOCKED",
            "NO_ACTION_REQUIRED",
            "INVALID_RESPONSE",
            "FAILED"
          ]
        },
        "eventStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "handoffStateStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "pickupStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "ackStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "branchName": {
          "type": [
            "string",
            "null"
          ]
        },
        "requestedOperation": {
          "type": [
            "string",
            "null"
          ]
        },
        "workspaceDir": {
          "type": [
            "string",
            "null"
          ]
        },
        "requestedEvent": {
          "type": [
            "string",
            "null"
          ]
        },
        "selectedEvent": {
          "type": [
            "string",
            "null"
          ]
        },
        "allowedEvents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "responseSource": {
          "type": "string",
          "minLength": 1
        },
        "resultingStateStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "currentCheckpoint": {
          "type": "string",
          "minLength": 1
        },
        "nextCheckpoint": {
          "type": "string",
          "minLength": 1
        },
        "currentActor": {
          "type": "string",
          "minLength": 1
        },
        "nextActor": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "transitionControl": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "path",
            "summaryPath",
            "generatedAt",
            "localOnly"
          ]
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotModifyGitOps",
        "doesNotCommit",
        "doesNotPush",
        "doesNotCreatePullRequest",
        "doesNotCallExternalGitProvider",
        "doesNotModifyKubernetes"
      ]
    }
  }
}
