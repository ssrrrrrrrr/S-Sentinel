{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/gitops-adapter-run.schema.json",
  "title": "S Sentinel GitOps Adapter Run",
  "description": "Local-only adapter run that validates a delivery workspace and emits a handoff readiness receipt without calling an external Git provider.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "gitopsAdapterRunId",
    "generatedBy",
    "generatedAt",
    "mode",
    "release",
    "inputs",
    "adapter",
    "run",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "gitops.adapter.run/v1alpha1"
    },
    "gitopsAdapterRunId": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "const": "local_gitops_adapter_run"
    },
    "release": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseId",
        "service",
        "env",
        "namespace",
        "policyDecision",
        "finalAction"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseEvidence",
        "gitopsAdapterDelivery",
        "gitopsAdapterResult",
        "gitopsAdapterRequest"
      ]
    },
    "adapter": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "adapter",
        "adapterType",
        "runMode",
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotCallExternalGitProvider"
      ]
    },
    "run": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "runStatus",
        "workspaceDir",
        "requestedOperation",
        "branchName",
        "summary",
        "checks",
        "pickupReceipt",
        "workspaceFiles"
      ],
      "properties": {
        "runStatus": {
          "type": "string",
          "enum": [
            "BLOCKED",
            "WAITING_APPROVAL",
            "HANDOFF_READY",
            "NO_ACTION_REQUIRED",
            "NEEDS_MORE_EVIDENCE",
            "FAILED"
          ]
        },
        "workspaceDir": {
          "type": [
            "string",
            "null"
          ]
        },
        "requestedOperation": {
          "type": [
            "string",
            "null"
          ]
        },
        "branchName": {
          "type": [
            "string",
            "null"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "checkId",
              "title",
              "status"
            ]
          }
        },
        "pickupReceipt": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "path",
            "summaryPath",
            "generatedAt",
            "localOnly"
          ]
        },
        "workspaceFiles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "fileId",
              "workspacePath",
              "exists",
              "contentType",
              "description"
            ]
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotModifyGitOps",
        "doesNotCommit",
        "doesNotPush",
        "doesNotCreatePullRequest",
        "doesNotCallExternalGitProvider",
        "doesNotModifyKubernetes"
      ]
    }
  }
}
