{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/gitops-adapter-payload.schema.json",
  "title": "S Sentinel GitOps Adapter Payload",
  "description": "Local-only pre-external GitOps payload materialized from the handoff progress, delivery workspace, and PR-ready bundle so a future external adapter can consume a stable commit-ready payload.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "gitopsAdapterPayloadId",
    "generatedBy",
    "generatedAt",
    "mode",
    "release",
    "inputs",
    "payload",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "gitops.adapter.payload/v1alpha1"
    },
    "gitopsAdapterPayloadId": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "const": "local_gitops_adapter_payload"
    },
    "release": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseId",
        "service",
        "env",
        "namespace",
        "policyDecision",
        "finalAction"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseEvidence",
        "gitopsAdapterHandoffProgress",
        "gitopsAdapterDelivery",
        "gitopsPRBundle",
        "gitopsHandoffBundle"
      ]
    },
    "payload": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "payloadStatus",
        "progressStatus",
        "branchName",
        "requestedOperation",
        "workspaceDir",
        "bundleDir",
        "payloadFiles",
        "patchEntryCount",
        "handoffFileCount",
        "workspaceArtifactCount",
        "summary",
        "payloadManifest"
      ],
      "properties": {
        "payloadStatus": {
          "type": "string",
          "enum": [
            "PAYLOAD_READY",
            "HANDOFF_IN_PROGRESS",
            "RETURNED_FOR_REWORK",
            "WAITING_APPROVAL",
            "BLOCKED",
            "NO_ACTION_REQUIRED",
            "NEEDS_MORE_EVIDENCE",
            "FAILED"
          ]
        },
        "progressStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "prepStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "transitionStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "eventStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "handoffStateStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "pickupStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "ackStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "branchName": {
          "type": [
            "string",
            "null"
          ]
        },
        "requestedOperation": {
          "type": [
            "string",
            "null"
          ]
        },
        "workspaceDir": {
          "type": [
            "string",
            "null"
          ]
        },
        "bundleDir": {
          "type": [
            "string",
            "null"
          ]
        },
        "payloadFiles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "fileId",
              "path",
              "contentType",
              "description"
            ]
          }
        },
        "patchEntryCount": {
          "type": "integer",
          "minimum": 0
        },
        "handoffFileCount": {
          "type": "integer",
          "minimum": 0
        },
        "workspaceArtifactCount": {
          "type": "integer",
          "minimum": 0
        },
        "payloadManifest": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "path",
            "summaryPath",
            "commitPayloadPath",
            "generatedAt",
            "localOnly"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotModifyGitOps",
        "doesNotCommit",
        "doesNotPush",
        "doesNotCreatePullRequest",
        "doesNotCallExternalGitProvider",
        "doesNotModifyKubernetes"
      ]
    }
  }
}
