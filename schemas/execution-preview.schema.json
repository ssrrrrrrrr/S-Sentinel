{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/execution-preview.schema.json",
  "title": "S Sentinel Execution Preview",
  "description": "Dry-run execution preview that explains what a controlled executor would do without changing GitOps or Kubernetes.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "executionPreviewId",
    "generatedBy",
    "generatedAt",
    "mode",
    "release",
    "inputs",
    "preview",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "execution.preview/v1alpha1"
    },
    "executionPreviewId": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "const": "dry_run_execution_preview"
    },
    "release": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseId",
        "service",
        "env",
        "namespace",
        "policyDecision",
        "finalAction"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseEvidence",
        "executionRequest",
        "executionEligibility",
        "actionPlan",
        "renderedReleasePlan",
        "environmentConfig",
        "supplyChainDecision"
      ]
    },
    "preview": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "previewStatus",
        "readyToExecute",
        "requestedAction",
        "summary",
        "plannedActions",
        "blockedActions",
        "humanCheckpoints",
        "gitopsChanges",
        "rolloutPlan"
      ],
      "properties": {
        "previewStatus": {
          "type": "string",
          "enum": [
            "BLOCKED",
            "NEEDS_MORE_EVIDENCE",
            "WAITING_APPROVAL",
            "READY_TO_EXECUTE",
            "NO_ACTION_REQUIRED"
          ]
        },
        "readyToExecute": {
          "type": "boolean"
        },
        "requestedAction": {
          "type": [
            "string",
            "null"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "targetEnvironment": {
          "type": "object",
          "additionalProperties": true
        },
        "plannedActions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "actionId",
              "title",
              "category",
              "dryRunOnly",
              "blocked",
              "requiresApproval"
            ]
          }
        },
        "blockedActions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "humanCheckpoints": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "gitopsChanges": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "rolloutPlan": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotModifyKubernetes",
        "doesNotModifyGitOps",
        "doesNotRollback",
        "doesNotPromote",
        "doesNotPatchResources",
        "doesNotDeleteResources",
        "doesNotBuildImages",
        "doesNotCommitOrPush"
      ]
    }
  }
}
