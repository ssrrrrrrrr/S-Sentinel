{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/gitops-adapter-delivery.schema.json",
  "title": "S Sentinel GitOps Adapter Delivery Workspace",
  "description": "Local-only delivery workspace emitted by the GitOps adapter stub so humans or future adapters can pick up a concrete handoff package without calling an external Git provider.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "gitopsAdapterDeliveryId",
    "generatedBy",
    "generatedAt",
    "mode",
    "release",
    "inputs",
    "adapter",
    "delivery",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "gitops.adapter.delivery/v1alpha1"
    },
    "gitopsAdapterDeliveryId": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "const": "local_gitops_adapter_delivery_workspace"
    },
    "release": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseId",
        "service",
        "env",
        "namespace",
        "policyDecision",
        "finalAction"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseEvidence",
        "gitopsAdapterResult",
        "gitopsAdapterRequest",
        "gitopsHandoffBundle"
      ]
    },
    "adapter": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "adapter",
        "adapterType",
        "deliveryMode",
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotCallExternalGitProvider"
      ]
    },
    "delivery": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "deliveryStatus",
        "workspaceDir",
        "manifestFile",
        "pickupInstructionsFile",
        "copiedFiles",
        "summary"
      ],
      "properties": {
        "deliveryStatus": {
          "type": "string",
          "enum": [
            "BLOCKED",
            "WAITING_APPROVAL",
            "WORKSPACE_READY",
            "NO_ACTION_REQUIRED",
            "NEEDS_MORE_EVIDENCE",
            "FAILED"
          ]
        },
        "workspaceDir": {
          "type": [
            "string",
            "null"
          ]
        },
        "manifestFile": {
          "type": [
            "string",
            "null"
          ]
        },
        "pickupInstructionsFile": {
          "type": [
            "string",
            "null"
          ]
        },
        "branchName": {
          "type": [
            "string",
            "null"
          ]
        },
        "requestedOperation": {
          "type": [
            "string",
            "null"
          ]
        },
        "copiedFiles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "fileId",
              "sourcePath",
              "workspacePath",
              "contentType",
              "description"
            ]
          }
        },
        "pickupInstructions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotModifyGitOps",
        "doesNotCommit",
        "doesNotPush",
        "doesNotCreatePullRequest",
        "doesNotCallExternalGitProvider",
        "doesNotModifyKubernetes"
      ]
    }
  }
}
