{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/gitops-adapter-provider-request.schema.json",
  "title": "S Sentinel GitOps Adapter Provider Request",
  "description": "Provider-ready GitOps PR request derived from the external adapter stub dispatch. It captures the exact branch, commit, and pull request intent that a real Git provider integration would need, while remaining local-only.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "gitopsAdapterProviderRequestId",
    "generatedBy",
    "generatedAt",
    "mode",
    "release",
    "inputs",
    "providerRequest",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "gitops.adapter.provider.request/v1alpha1"
    },
    "gitopsAdapterProviderRequestId": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "const": "provider_ready_gitops_pr_request"
    },
    "release": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseId",
        "service",
        "env",
        "namespace",
        "policyDecision",
        "finalAction"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseEvidence",
        "gitopsAdapterDispatch",
        "gitopsAdapterPayload",
        "gitopsPRBundle"
      ]
    },
    "providerRequest": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "requestStatus",
        "providerType",
        "branchName",
        "requestedOperation",
        "commitMessage",
        "pullRequestTitle",
        "pullRequestBodyPath",
        "payloadManifestPath",
        "commitPayloadPath",
        "summary"
      ],
      "properties": {
        "requestStatus": {
          "type": "string",
          "enum": [
            "PROVIDER_REQUEST_READY",
            "WAITING_APPROVAL",
            "BLOCKED",
            "RETURNED_FOR_REWORK",
            "NO_ACTION_REQUIRED",
            "NEEDS_MORE_EVIDENCE",
            "FAILED"
          ]
        },
        "providerType": {
          "type": "string",
          "minLength": 1
        },
        "branchName": {
          "type": [
            "string",
            "null"
          ]
        },
        "requestedOperation": {
          "type": [
            "string",
            "null"
          ]
        },
        "commitMessage": {
          "type": [
            "string",
            "null"
          ]
        },
        "pullRequestTitle": {
          "type": [
            "string",
            "null"
          ]
        },
        "pullRequestBodyPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "payloadManifestPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "commitPayloadPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "providerRequestPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "patchEntryCount": {
          "type": "integer",
          "minimum": 0
        },
        "workspaceArtifactCount": {
          "type": "integer",
          "minimum": 0
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotModifyGitOps",
        "doesNotCommit",
        "doesNotPush",
        "doesNotCreatePullRequest",
        "doesNotCallExternalGitProvider",
        "doesNotModifyKubernetes"
      ]
    }
  }
}
