{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://s-sentinel.local/schemas/compiler-profile.schema.json",
  "title": "S Sentinel Compiler Profile",
  "description": "Compiler profile contract for service/runtime/metric/rendering model selection.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "compiler.ssentinel.io/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "CompilerProfile"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "service"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "service": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string" },
        "env": { "type": "string" },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": true,
      "required": ["serviceConfig", "runtimeProfile", "metricBinding", "rendererRefs", "guardrails"],
      "properties": {
        "description": { "type": "string" },
        "serviceConfig": { "type": "object", "additionalProperties": true },
        "runtimeProfile": { "type": "object", "additionalProperties": true },
        "metricBinding": { "type": "object", "additionalProperties": true },
        "rendererRefs": { "type": "object", "additionalProperties": true },
        "guardrails": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
