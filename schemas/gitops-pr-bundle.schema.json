{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/gitops-pr-bundle.schema.json",
  "title": "S Sentinel GitOps PR Bundle",
  "description": "PR-ready GitOps handoff bundle derived from the review-only patch proposal.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "gitopsPRBundleId",
    "generatedBy",
    "generatedAt",
    "mode",
    "release",
    "inputs",
    "bundle",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "gitops.pr.bundle/v1alpha1"
    },
    "gitopsPRBundleId": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "const": "review_only_gitops_pr_bundle"
    },
    "release": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseId",
        "service",
        "env",
        "namespace",
        "policyDecision",
        "finalAction"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseEvidence",
        "gitopsPatchProposal",
        "executionPreview",
        "executionResult"
      ]
    },
    "bundle": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "bundleStatus",
        "branchName",
        "commitMessage",
        "pullRequest",
        "patchEntries",
        "handoffChecklist"
      ],
      "properties": {
        "bundleStatus": {
          "type": "string",
          "enum": [
            "BLOCKED",
            "WAITING_APPROVAL",
            "READY_FOR_REVIEW",
            "NO_CHANGES_REQUIRED",
            "NEEDS_MORE_EVIDENCE"
          ]
        },
        "branchName": {
          "type": [
            "string",
            "null"
          ]
        },
        "commitMessage": {
          "type": [
            "string",
            "null"
          ]
        },
        "repository": {
          "type": "object",
          "additionalProperties": true
        },
        "pullRequest": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "title",
            "body"
          ]
        },
        "patchEntries": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "entryId",
              "path",
              "summary",
              "changeType",
              "dryRunOnly"
            ]
          }
        },
        "handoffChecklist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotModifyGitOps",
        "doesNotCommit",
        "doesNotPush",
        "doesNotCreatePullRequest",
        "doesNotModifyKubernetes"
      ]
    }
  }
}
