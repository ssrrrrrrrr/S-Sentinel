{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/gitops-adapter-handoff-progress.schema.json",
  "title": "S Sentinel GitOps Adapter Handoff Progress",
  "description": "Local-only handoff progression result derived from the handoff prep state. It records whether the local handoff is waiting to start, in progress, completed, or returned for rework without committing, pushing, creating pull requests, or modifying Kubernetes.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "gitopsAdapterHandoffProgressId",
    "generatedBy",
    "generatedAt",
    "mode",
    "release",
    "inputs",
    "handoffProgress",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "gitops.adapter.handoff.progress/v1alpha1"
    },
    "gitopsAdapterHandoffProgressId": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "const": "local_gitops_adapter_handoff_progress"
    },
    "release": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseId",
        "service",
        "env",
        "namespace",
        "policyDecision",
        "finalAction"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseEvidence",
        "gitopsAdapterHandoffPrep",
        "gitopsAdapterPickupTransition",
        "gitopsAdapterHandoffState"
      ]
    },
    "handoffProgress": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "progressStatus",
        "prepStatus",
        "transitionStatus",
        "resultingStateStatus",
        "pickupStatus",
        "ackStatus",
        "branchName",
        "requestedOperation",
        "workspaceDir",
        "selectedAction",
        "actionSource",
        "currentCheckpoint",
        "nextCheckpoint",
        "currentActor",
        "nextActor",
        "summary",
        "progressControl"
      ],
      "properties": {
        "progressStatus": {
          "type": "string",
          "enum": [
            "WAITING_TO_START",
            "HANDOFF_IN_PROGRESS",
            "HANDOFF_COMPLETED",
            "RETURNED_FOR_REWORK",
            "WAITING_APPROVAL",
            "BLOCKED",
            "NO_ACTION_REQUIRED",
            "INVALID_ACTION",
            "FAILED"
          ]
        },
        "prepStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "transitionStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "eventStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "handoffStateStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "resultingStateStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "pickupStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "ackStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "branchName": {
          "type": [
            "string",
            "null"
          ]
        },
        "requestedOperation": {
          "type": [
            "string",
            "null"
          ]
        },
        "workspaceDir": {
          "type": [
            "string",
            "null"
          ]
        },
        "selectedEvent": {
          "type": [
            "string",
            "null"
          ]
        },
        "selectedAction": {
          "type": [
            "string",
            "null"
          ]
        },
        "actionSource": {
          "type": [
            "string",
            "null"
          ]
        },
        "currentCheckpoint": {
          "type": "string",
          "minLength": 1
        },
        "nextCheckpoint": {
          "type": "string",
          "minLength": 1
        },
        "currentActor": {
          "type": "string",
          "minLength": 1
        },
        "nextActor": {
          "type": "string",
          "minLength": 1
        },
        "workspaceArtifactCount": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "progressControl": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "path",
            "summaryPath",
            "generatedAt",
            "localOnly"
          ]
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotModifyGitOps",
        "doesNotCommit",
        "doesNotPush",
        "doesNotCreatePullRequest",
        "doesNotCallExternalGitProvider",
        "doesNotModifyKubernetes"
      ]
    }
  }
}
