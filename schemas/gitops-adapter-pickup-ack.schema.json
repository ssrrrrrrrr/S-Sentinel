{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://s-sentinel.local/schemas/gitops-adapter-pickup-ack.schema.json",
  "title": "S Sentinel GitOps Adapter Pickup Acknowledgement",
  "description": "Local-only acknowledgement state for a GitOps pickup handoff. It records whether the pickup is waiting, accepted, returned, or completed without calling an external Git provider.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "gitopsAdapterPickupAckId",
    "generatedBy",
    "generatedAt",
    "mode",
    "release",
    "inputs",
    "acknowledgement",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "gitops.adapter.pickup.ack/v1alpha1"
    },
    "gitopsAdapterPickupAckId": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "const": "local_gitops_adapter_pickup_ack"
    },
    "release": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseId",
        "service",
        "env",
        "namespace",
        "policyDecision",
        "finalAction"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "releaseEvidence",
        "gitopsAdapterPickup",
        "gitopsAdapterRun",
        "gitopsAdapterDelivery"
      ]
    },
    "acknowledgement": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "ackStatus",
        "pickupStatus",
        "branchName",
        "requestedOperation",
        "workspaceDir",
        "assignedActor",
        "nextCheckpoint",
        "summary",
        "ackControl"
      ],
      "properties": {
        "ackStatus": {
          "type": "string",
          "enum": [
            "BLOCKED",
            "WAITING_APPROVAL",
            "WAITING_FOR_ACK",
            "ACKNOWLEDGED",
            "RETURNED",
            "NO_ACTION_REQUIRED",
            "FAILED"
          ]
        },
        "pickupStatus": {
          "type": [
            "string",
            "null"
          ]
        },
        "branchName": {
          "type": [
            "string",
            "null"
          ]
        },
        "requestedOperation": {
          "type": [
            "string",
            "null"
          ]
        },
        "workspaceDir": {
          "type": [
            "string",
            "null"
          ]
        },
        "assignedActor": {
          "type": "string",
          "minLength": 1
        },
        "nextCheckpoint": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "ackControl": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "path",
            "summaryPath",
            "generatedAt",
            "localOnly"
          ]
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "readOnly",
        "dryRunOnly",
        "willExecute",
        "doesNotModifyGitOps",
        "doesNotCommit",
        "doesNotPush",
        "doesNotCreatePullRequest",
        "doesNotCallExternalGitProvider",
        "doesNotModifyKubernetes"
      ]
    }
  }
}
