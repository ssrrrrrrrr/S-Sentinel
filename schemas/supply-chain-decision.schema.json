{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "S Sentinel Supply Chain Safety Decision",
  "type": "object",
  "required": [
    "schemaVersion",
    "supplyChainDecisionId",
    "generatedBy",
    "generatedAt",
    "mode",
    "release",
    "image",
    "gitops",
    "checks",
    "decision",
    "risk",
    "guardrails"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "supply.chain.decision/v1alpha1"
    },
    "supplyChainDecisionId": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "read_only_supply_chain_check"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": true
    },
    "release": {
      "type": "object",
      "required": [
        "releaseId"
      ],
      "properties": {
        "releaseId": {
          "type": "string",
          "minLength": 1
        },
        "service": {
          "type": [
            "string",
            "null"
          ]
        },
        "env": {
          "type": [
            "string",
            "null"
          ]
        },
        "namespace": {
          "type": [
            "string",
            "null"
          ]
        },
        "rollout": {
          "type": [
            "string",
            "null"
          ]
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        },
        "commit": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "image": {
      "type": "object",
      "properties": {
        "image": {
          "type": [
            "string",
            "null"
          ]
        },
        "imageTag": {
          "type": [
            "string",
            "null"
          ]
        },
        "imageDigest": {
          "type": [
            "string",
            "null"
          ]
        },
        "usesDigestReference": {
          "type": "boolean"
        },
        "usesMutableTag": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "gitops": {
      "type": "object",
      "properties": {
        "manifest": {
          "type": [
            "string",
            "null"
          ]
        },
        "manifestFound": {
          "type": "boolean"
        },
        "rollout": {
          "type": [
            "string",
            "null"
          ]
        },
        "namespace": {
          "type": [
            "string",
            "null"
          ]
        },
        "image": {
          "type": [
            "string",
            "null"
          ]
        },
        "imageTag": {
          "type": [
            "string",
            "null"
          ]
        },
        "releaseTag": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "checkId",
          "status",
          "severity",
          "message"
        ],
        "properties": {
          "checkId": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "WARN",
              "FAIL"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "none",
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "message": {
            "type": "string"
          },
          "evidence": {
            "type": "object"
          }
        },
        "additionalProperties": true
      }
    },
    "decision": {
      "type": "object",
      "required": [
        "decision",
        "requiresHumanApproval",
        "allowed",
        "blockingReasons",
        "warningReasons"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": [
            "ALLOW",
            "REQUIRE_HUMAN_APPROVAL",
            "BLOCK"
          ]
        },
        "requiresHumanApproval": {
          "type": "boolean"
        },
        "allowed": {
          "type": "boolean"
        },
        "blockingReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "warningReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "risk": {
      "type": "object",
      "required": [
        "riskLevel",
        "riskScore"
      ],
      "properties": {
        "riskLevel": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "riskScore": {
          "type": [
            "integer",
            "number"
          ],
          "minimum": 0,
          "maximum": 100
        }
      },
      "additionalProperties": true
    },
    "guardrails": {
      "type": "object",
      "required": [
        "readOnly",
        "willExecute",
        "doesNotModifyKubernetes",
        "doesNotModifyGitOps",
        "doesNotBuildImages",
        "doesNotPushImages",
        "doesNotCommitOrPush"
      ],
      "properties": {
        "readOnly": {
          "type": "boolean"
        },
        "willExecute": {
          "type": "boolean"
        },
        "doesNotModifyKubernetes": {
          "type": "boolean"
        },
        "doesNotModifyGitOps": {
          "type": "boolean"
        },
        "doesNotBuildImages": {
          "type": "boolean"
        },
        "doesNotPushImages": {
          "type": "boolean"
        },
        "doesNotCommitOrPush": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
